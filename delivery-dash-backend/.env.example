# Copy to `.env` and fill in. `.env` is gitignored by the docker context via .dockerignore.
# Nested config uses `__` (double underscore) on Linux — e.g. ConnectionStrings:DbConnectionString -> ConnectionStrings__DbConnectionString.

ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080

ConnectionStrings__DbConnectionString=Host=...neon.tech;Port=5432;Database=...;User Id=...;Password=...;SSL Mode=Require;Trust Server Certificate=true
JwtOptions__SecretKey=replace-with-a-long-random-string-at-least-32-chars
ApiKey=DeliveryDash-Api-Key

Redis__ConnectionString=rediss://default:...@...upstash.io:6379

Email__SmtpPassword=
