{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DbConnectionString": "Host=localhost;port=5432;Database=DeliveryDash;User Id=postgres;password=root"
  },
  "ApiKey": "",
  "JwtOptions": {
    "Issuer": "DeliveryDashApi",
    "Audience": "DeliveryDashClient",
    "ExpiryInMinutes": 15,
    "SecretKey": ""
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1s",
        "Limit": 5
      },
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 100
      },
      {
        "Endpoint": "*",
        "Period": "1h",
        "Limit": 1000
      }
    ]
  },
  "IpRateLimitPolicies": {
    "IpRules": [
      {
        "Ip": "127.0.0.1",
        "Rules": [
          {
            "Endpoint": "*",
            "Period": "1s",
            "Limit": 1000
          }
        ]
      }
    ]
  },
  "FileStorage": {
    "UploadPath": "Uploads",
    "AllowedExtensions": [
      ".jpg",
      ".jpeg",
      ".png",
      ".gif",
      ".webp"
    ],
    "MaxFileSizeInBytes": 5242880
  },
  "Redis": {
    "ConnectionString": "",
    "AbortOnConnectFail": false,
    "ConnectTimeout": 5000,
    "SyncTimeout": 5000,
    "InstanceName": "DeliveryDash:"
  },
  "Firebase": {
    "ServiceAccountPath": ""
  },
  "NotificationSettings": {
    "MaxNotificationsPerUser": 100,
    "RetentionDays": 30,
    "EnableRealTimeNotifications": true
  },
  "DashboardCache": {
    "AdminDashboardCacheDurationMinutes": 30,
    "VendorDashboardCacheDurationMinutes": 30
  },
  "VendorTimeout": {
    "TimeoutMinutes": 2,
    "CheckIntervalSeconds": 30
  },
  "Email": {
    "SmtpHost": "smtp.gmail.com",
    "SmtpPort": "587",
    "SmtpUser": "maldashtesting@gmail.com",
    "SmtpPassword": "",
    "FromEmail": "maldashtesting@gmail.com",
    "FromName": "DeliveryDash"
  }
}